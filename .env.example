# Anthropic — генерация текста
ANTHROPIC_API_KEY=sk-ant-...

# Replicate — генерация обложек (FLUX)
REPLICATE_API_TOKEN=r8_...

# Telegram
TG_BOT_TOKEN=123456:ABC-DEF...
TG_CHANNEL_ID=@mychannel

# ВКонтакте
VK_TOKEN=vk1.a....
VK_GROUP_ID=123456789

# MAX (MTS-мессенджер)
MAX_BOT_TOKEN=...
MAX_CHANNEL_ID=...

# VC.ru (Osnova API)
# Токен: vc.ru → Настройки → Безопасность → Активные сессии / API → Создать токен
# Subsite ID: зайдите на свой профиль, в URL /id{число} — это и есть ID
VC_TOKEN=...
VC_SUBSITE_ID=123456
